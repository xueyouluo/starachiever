PORT=3001
HOST=0.0.0.0
DATABASE_PATH=./data/starachiever.sqlite
JWT_SECRET=change-this-to-a-long-random-secret
ADMIN_READ_TOKEN=change-this-to-a-long-random-admin-token
EINK_DEVICE_TOKEN=change-this-to-a-long-random-eink-device-token
EINK_USER_TOKEN_SECRET=change-this-to-a-long-random-eink-user-token-secret
CHROME_EXECUTABLE_PATH=/usr/bin/chromium-browser
WECHAT_APP_ID=your-wechat-mini-program-appid
WECHAT_APP_SECRET=your-wechat-mini-program-secret

# Local API tests can set this to true so /api/auth/wechat does not call WeChat.
WECHAT_AUTH_MOCK=false
